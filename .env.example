# CareLoop — environment variables
# Copy to `.env.local` for local dev. Never commit real secrets.

# --- Supabase (REQUIRED — the persistent backend) --------------------------
# Project URL + service-role key from the Supabase dashboard:
#   Project Settings -> API -> Project URL  and  service_role (secret) key.
# The service-role key is SERVER-ONLY (it bypasses Row Level Security). Never
# expose it to the browser. Without these, the app cannot read/write data.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Enables AI-assisted wording for the weekly clinician summary.
# Without it, CareLoop uses a deterministic template (the demo still works fully).
ANTHROPIC_API_KEY=

# Optional. Override the Claude model used for summary wording.
# Defaults to claude-sonnet-4-6.
CARELOOP_SUMMARY_MODEL=

# Optional. Override the Claude model used for WhatsApp symptom extraction.
# Defaults to claude-sonnet-4-6.
CARELOOP_EXTRACT_MODEL=

# --- WhatsApp voice-note pipeline (optional) -------------------------------
# Twilio WhatsApp sandbox credentials. Needed only to download inbound voice
# notes (text messages work without them). Find them in the Twilio console.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Optional. Maps every inbound WhatsApp message to this demo patient.
# Defaults to patient-mrs-chan.
CARELOOP_WHATSAPP_PATIENT=

# Speech-to-text for voice notes. Set ONE: Groq (free Whisper, default) or OpenAI.
# Without either, a voice note falls back to a pinned demo transcript; text
# messages and AI extraction still work fully.
GROQ_API_KEY=
OPENAI_API_KEY=
# Optional. Override the STT model (Groq: whisper-large-v3, OpenAI: whisper-1).
CARELOOP_STT_MODEL=
# Optional. Force STT language (e.g. zh). Empty = auto-detect.
CARELOOP_STT_LANGUAGE=

# --- Outbound + scheduler (optional) ---------------------------------------
# Patient WhatsApp number for the outbound daily check-in if not captured from an
# inbound message. Format: whatsapp:+<E.164>.
CARELOOP_DEMO_PATIENT_PHONE=
# Twilio sandbox sender. Defaults to whatsapp:+14155238886.
TWILIO_WHATSAPP_FROM=
# Daily scheduler time (HH:MM) + timezone. Empty = scheduler off.
CARELOOP_CHECKIN_TIME=
CARELOOP_TZ=

# --- Onboarding QR (optional) ----------------------------------------------
# Twilio sandbox number + join code shown on the /onboard page.
CARELOOP_WHATSAPP_SANDBOX_NUMBER=
CARELOOP_WHATSAPP_JOIN_CODE=

# --- Cron (optional) -------------------------------------------------------
# If set, the agent endpoints (/api/agent/send-checkin GET = the Vercel daily
# cron, and POST/send-round) require `Authorization: Bearer <CRON_SECRET>`.
# Vercel Cron sends this header automatically for scheduled runs. Leave empty
# to keep the in-app trigger buttons open (demo default).
CRON_SECRET=
