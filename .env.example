# CareLoop HK — environment variables
# Copy to `.env.local` for local dev. Never commit real secrets.

# Optional. Enables AI-assisted wording for the weekly clinician summary.
# Without it, CareLoop uses a deterministic template (the demo still works fully).
ANTHROPIC_API_KEY=

# Optional. Override the Claude model used for summary wording.
# Defaults to claude-sonnet-4-6.
CARELOOP_SUMMARY_MODEL=
