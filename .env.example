# Miruwa — environment variables
# Copy to `.env.local` for local dev. Never commit real secrets.
# Full deployment instructions: see DEPLOYMENT.md.

# --- Supabase (REQUIRED — backend + authentication) -------------------------
# Project URL + keys from the Supabase dashboard:
#   Project Settings -> API -> Project URL, anon (public) key, service_role key.
# The service-role key is SERVER-ONLY (it bypasses Row Level Security). Never
# expose it to the browser. The anon key is safe for the browser: RLS denies it
# all table access; it is used only for the nurse/admin login session.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Site --------------------------------------------------------------------
# Canonical site origin (https://your-domain). Used for SEO metadata and the
# Origin CSRF check on mutating API requests.
NEXT_PUBLIC_SITE_URL=

# Demo mode. "true" enables the demo tooling (reset, risky check-in replay,
# frozen demo clock) for admin users. NEVER enable on a real hospital
# deployment — demo mode freezes the clinical date to the seeded demo week.
DEMO_MODE=

# --- AI (optional) -----------------------------------------------------------
# Enables AI-assisted wording for summaries/extraction. Without it, Miruwa
# uses deterministic templates (everything still works).
ANTHROPIC_API_KEY=
# Optional model overrides. Default: claude-sonnet-4-6.
CARELOOP_SUMMARY_MODEL=
CARELOOP_EXTRACT_MODEL=

# --- WhatsApp (optional) -------------------------------------------------------
# Twilio credentials. Needed for outbound check-ins + downloading voice notes.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# REQUIRED IN PRODUCTION when Twilio is configured: the exact public URL of the
# inbound webhook as registered in the Twilio console, e.g.
# https://your-domain/api/whatsapp/inbound — used to validate X-Twilio-Signature.
# Must match byte-for-byte or all inbound webhooks are rejected.
TWILIO_WEBHOOK_URL=
# Optional. Maps every inbound WhatsApp message to this demo patient (demo only).
CARELOOP_WHATSAPP_PATIENT=

# Speech-to-text for voice notes. Set ONE: Groq (free Whisper, default) or OpenAI.
# Without either, a voice note falls back to a pinned demo transcript.
GROQ_API_KEY=
OPENAI_API_KEY=
# Optional. Override the STT model (Groq: whisper-large-v3, OpenAI: whisper-1).
CARELOOP_STT_MODEL=
# Optional. Force STT language (e.g. zh). Empty = auto-detect.
CARELOOP_STT_LANGUAGE=

# --- Outbound + scheduler (optional) ---------------------------------------
# Patient WhatsApp number for the outbound daily check-in if not captured from an
# inbound message. Format: whatsapp:+<E.164>.
CARELOOP_DEMO_PATIENT_PHONE=
# Twilio sandbox sender. Defaults to whatsapp:+14155238886.
TWILIO_WHATSAPP_FROM=
# In-process daily scheduler (self-hosted/Docker only; on Vercel use Vercel Cron).
# Daily send time (HH:MM) + timezone. Empty = scheduler off.
CARELOOP_CHECKIN_TIME=
CARELOOP_TZ=

# --- Onboarding QR (optional) ----------------------------------------------
# Twilio sandbox number + join code shown on the /onboard page.
CARELOOP_WHATSAPP_SANDBOX_NUMBER=
CARELOOP_WHATSAPP_JOIN_CODE=

# --- Cron (REQUIRED in production) -------------------------------------------
# Bearer token for the agent endpoints (/api/agent/*). Vercel Cron sends
# `Authorization: Bearer <CRON_SECRET>` automatically. In production the agent
# endpoints FAIL CLOSED if this is unset. Leave empty in local dev to keep the
# in-app trigger buttons open.
CRON_SECRET=

# --- Rate limiting (recommended in production) --------------------------------
# Upstash Redis REST credentials. Without them rate limiting falls back to a
# per-instance in-memory limiter (fine for dev, weak on serverless).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Error tracking (optional) -------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Leads / contact form (vendor & demo instance only) --------------------------
# Resend API key for emailing new demo requests. Without it, leads are still
# stored in the database (Settings -> Leads) — only the email ping is skipped.
RESEND_API_KEY=
# Where lead notifications are sent. Required for email delivery.
LEADS_NOTIFY_EMAIL=
# Verified Resend sender. Defaults to "Miruwa <onboarding@resend.dev>" (only
# delivers to the Resend account owner until you verify a sending domain).
RESEND_FROM_EMAIL=
